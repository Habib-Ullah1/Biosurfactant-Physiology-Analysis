# =============================================================================
# .gitignore — Biosurfactant Physiology Analysis
# =============================================================================

# Raw data — unpublished experimental files, keep on HPC only
data/raw/
*.xlsx
*.xls

# Large intermediate R objects
*.rda
*.rds
*.RData
*.Rhistory
*.Rproj.user/

# Results that can be regenerated by running scripts
# (keep summary TSVs but ignore large intermediate files)
results/**/*.rda
results/**/*.rds
results/**/Rplots.pdf

# Figures — track in repo (they are outputs we want versioned)
# Exception: do NOT ignore figures/
!figures/

# Log files from HPC jobs
results/logs/
*.log
*.err
jobs/*.o*
jobs/*.e*

# OS files
.DS_Store
Thumbs.db
.Spotlight-V100
.Trashes

# Editor files
.vscode/
*.swp
*.swo
*~

# Temporary R files
.Ruserdata
**/.Rproj.user

# WGS input symlinks — tracked as plain files when pushed to GitHub
# (symlinks work on HPC; on GitHub they appear as text files pointing to paths)
# No special handling needed — git follows symlinks by default

# Python cache (if any helper scripts are used)
__pycache__/
*.pyc
*.pyo

# Conda / virtual environments
.conda/
venv/
